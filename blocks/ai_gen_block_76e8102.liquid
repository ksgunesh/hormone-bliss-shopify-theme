    {
      "type": "range",
      "id": "masonry_row_height_mobile",
      "label": "Masonry row height (mobile)",
      "min": 30,
      "max": 100,
      "step": 10,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 0
