{% doc %}
  @prompt
    Create a masonry grid for testimonials. Need a field for the testimonial and a separate field for the name. Allow each tile to have a background, with border radius, padding and border color., The row height should be auto
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-testimonial-masonry-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
  }

  .ai-testimonial-masonry__grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    gap: {{ block.settings.gap }}px;
    grid-auto-rows: auto;
  }

  .ai-testimonial-masonry__item-{{ ai_gen_id }} {
    background-color: {{ block.settings.tile_background }};
    border: {{ block.settings.border_width }}px solid {{ block.settings.border_color }};
    border-radius: {{ block.settings.border_radius }}px;
    padding: {{ block.settings.padding }}px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 16px;
    transition: transform 0.2s ease;
  }

  .ai-testimonial-masonry__item-{{ ai_gen_id }}:nth-child(3n + 1) {
    grid-row: span 2;
  }

  .ai-testimonial-masonry__item-{{ ai_gen_id }}:nth-child(3n + 2) {
    grid-row: span 3;
  }

  .ai-testimonial-masonry__item-{{ ai_gen_id }}:nth-child(3n + 3) {
    grid-row: span 2;
  }

  .ai-testimonial-masonry__text-{{ ai_gen_id }} {
    font-size: {{ block.settings.text_size }}px;
    line-height: 1.5;
    color: {{ block.settings.text_color }};
  }

  .ai-testimonial-masonry__author-{{ ai_gen_id }} {
    font-size: {{ block.settings.author_size }}px;
    font-weight: 600;
    color: {{ block.settings.author_color }};
    margin-top: auto;
  }

  @media screen and (max-width: 749px) {
    .ai-testimonial-masonry__grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
    }
  }
{% endstyle %}

<testimonial-masonry-{{ ai_gen_id }} class="ai-testimonial-masonry-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-testimonial-masonry__grid-{{ ai_gen_id }}">
    {% for i in (1..6) %}
      {% liquid
        assign testimonial_key = 'testimonial_' | append: i
        assign author_key = 'author_' | append: i
        assign testimonial = block.settings[testimonial_key]
        assign author = block.settings[author_key]
      %}
      
      {% if testimonial != blank or author != blank %}
        <div class="ai-testimonial-masonry__item-{{ ai_gen_id }}">
          {% if testimonial != blank %}
            <div class="ai-testimonial-masonry__text-{{ ai_gen_id }}">
              {{ testimonial }}
            </div>
          {% endif %}
          {% if author != blank %}
            <div class="ai-testimonial-masonry__author-{{ ai_gen_id }}">
              {{ author }}
            </div>
          {% endif %}
        </div>
      {% endif %}
    {% endfor %}
  </div>
</testimonial-masonry-{{ ai_gen_id }}>

<script>
  (function() {
    class TestimonialMasonry{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.adjustMasonryLayout();
        window.addEventListener('resize', () => this.adjustMasonryLayout());
      }

      adjustMasonryLayout() {
        const items = this.querySelectorAll('.ai-testimonial-masonry__item-{{ ai_gen_id }}');
        items.forEach((item, index) => {
          const pattern = index % 3;
          if (pattern === 0) {
            item.style.gridRow = 'span 2';
          } else if (pattern === 1) {
            item.style.gridRow = 'span 3';
          } else {
            item.style.gridRow = 'span 2';
          }
        });
      }
    }

    customElements.define('testimonial-masonry-{{ ai_gen_id }}', TestimonialMasonry{{ ai_gen_id }});
  })();
</script>

