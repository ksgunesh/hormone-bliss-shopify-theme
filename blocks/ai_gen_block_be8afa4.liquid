{% doc %}
  @prompt
    Want to create an Icon Grid where the grid can be from 1 to 6 columns, each tile should have an icon, title and description. Can have up to 24 tiles. Tiles should have the ability to add a border and background with padding and gap
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-icon-grid-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
  }

  .ai-icon-grid__container-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    gap: {{ block.settings.grid_gap }}px;
  }

  .ai-icon-grid__tile-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: {{ block.settings.tile_alignment }};
    text-align: {{ block.settings.tile_text_alignment }};
    padding: {{ block.settings.tile_padding }}px;
    background-color: {{ block.settings.tile_background_color }};
    border-radius: {{ block.settings.tile_border_radius }}px;
    {% if block.settings.show_tile_border %}
      border: {{ block.settings.tile_border_width }}px solid {{ block.settings.tile_border_color }};
    {% endif %}
  }

  .ai-icon-grid__icon-wrapper-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    margin-bottom: {{ block.settings.icon_spacing }}px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-icon-grid__icon-wrapper-{{ ai_gen_id }} svg {
    height: 100%;
    color: {{ block.settings.icon_color }};
    width: 100%;
  }

  .ai-icon-grid__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    font-weight: {{ block.settings.title_weight }};
    color: {{ block.settings.title_color }};
    margin: 0 0 {{ block.settings.title_spacing }}px 0;
  }

  .ai-icon-grid__description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_size }}px;
    color: {{ block.settings.description_color }};
    margin: 0;
    line-height: 1.5;
  }

  @media screen and (max-width: 749px) {
    .ai-icon-grid__container-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
    }
  }
{% endstyle %}

<icon-grid-{{ ai_gen_id }} class="ai-icon-grid-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-icon-grid__container-{{ ai_gen_id }}">
    {% for i in (1..24) %}
      {% liquid
        assign tile_enabled_key = 'tile_' | append: i | append: '_enabled'
        assign tile_icon_key = 'tile_' | append: i | append: '_icon'
        assign tile_title_key = 'tile_' | append: i | append: '_title'
        assign tile_description_key = 'tile_' | append: i | append: '_description'

        assign tile_enabled = block.settings[tile_enabled_key]
        assign tile_icon = block.settings[tile_icon_key]
        assign tile_title = block.settings[tile_title_key]
        assign tile_description = block.settings[tile_description_key]
      %}

      {% if tile_enabled %}
        <div class="ai-icon-grid__tile-{{ ai_gen_id }}">
          {% if tile_icon %}
            <div class="ai-icon-grid__icon-wrapper-{{ ai_gen_id }}">
              <i class="{{ tile_icon }}"></i>
            </div>
          {% endif %}

          {% if tile_title != blank %}
            <h3 class="ai-icon-grid__title-{{ ai_gen_id }}">{{ tile_title }}</h3>
          {% endif %}

          {% if tile_description != blank %}
            <p class="ai-icon-grid__description-{{ ai_gen_id }}">{{ tile_description }}</p>
          {% endif %}
        </div>
      {% endif %}
    {% endfor %}
  </div>
</icon-grid-{{ ai_gen_id }}>

<script>
  (function() {
    class IconGrid{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.style.display = 'block';
      }
    }

    customElements.define('icon-grid-{{ ai_gen_id }}', IconGrid{{ ai_gen_id }});
  })();
</script>

