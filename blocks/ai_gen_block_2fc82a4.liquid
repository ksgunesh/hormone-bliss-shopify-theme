{% doc %}
  @prompt
    Build A Word Cloud
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-word-cloud-{{ ai_gen_id }} {
    display: block;
    max-width: 100%;
    padding: {{ block.settings.padding }}px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
    border-bottom: {{ block.settings.border_size }}px solid {{ block.settings.border_color }};
    border-top: {{ block.settings.border_size }}px solid {{ block.settings.border_color }};
  }

  .ai-word-cloud-container-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: {{ block.settings.word_spacing }}px;
  }

  .ai-word-cloud-word-{{ ai_gen_id }} {
    display: inline-block;
    cursor: pointer;
    padding: 8px 16px;
    transition: all 0.3s ease;
    border-radius: {{ block.settings.word_border_radius }}px;
    font-family: {{ block.settings.word_font.family }}, {{ block.settings.word_font.fallback_families }};
    font-weight: {{ block.settings.word_font.weight }};
    line-height: 1.2;
    text-align: center;
  }

  .ai-word-cloud-word-{{ ai_gen_id }}:hover {
    transform: scale(1.1);
    opacity: 0.8;
  }

  @media screen and (max-width: 749px) {
    .ai-word-cloud-container-{{ ai_gen_id }} span {
      transform: scale(0.8);
      padding: 4px;
    }
  }

  @media screen and (min-width: 749px) {
    .ai-word-cloud-{{ ai_gen_id }} {
      width: {{ block.settings.desktop_width_percent }}%;
    }
  }
{% endstyle %}

<word-cloud-{{ ai_gen_id }}
  class="ai-word-cloud-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-word-cloud-container-{{ ai_gen_id }}">
    {% liquid
      assign words_array = ''
      for i in (1..20)
        assign word_key = 'word_' | append: i
        assign size_key = 'word_' | append: i | append: '_size'
        assign color_key = 'word_' | append: i | append: '_color'
        assign url_key = 'word_' | append: i | append: '_url'
        
        assign word_text = block.settings[word_key]
        assign word_size = block.settings[size_key]
        assign word_color = block.settings[color_key]
        assign word_url = block.settings[url_key]
        
        if word_text != blank
          echo '<span class="ai-word-cloud-word-' | append: ai_gen_id | append: '" style="font-size: ' | append: word_size | append: 'px; color: ' | append: word_color | append: ';" data-url="' | append: word_url | append: '">'
          echo word_text
          echo '</span>'
        endif
      endfor
    %}
  </div>
</word-cloud-{{ ai_gen_id }}>

<script>
  (function() {
    class WordCloud{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.words = this.querySelectorAll('.ai-word-cloud-word-{{ ai_gen_id }}');
        this.setupEventListeners();
        this.randomizePositions();
      }

      setupEventListeners() {
        this.words.forEach((word) => {
          word.addEventListener('click', () => {
            const url = word.getAttribute('data-url');
            if (url && url !== '') {
              window.location.href = url;
            }
          });
        });
      }

      randomizePositions() {
        const wordsArray = Array.from(this.words);
        
        for (let i = wordsArray.length - 1; i > 0; i--) {
          const j = Math.floor(Math.random() * (i + 1));
          const parent = wordsArray[i].parentNode;
          const sibling = wordsArray[i].nextSibling === wordsArray[j] ? wordsArray[i] : wordsArray[i].nextSibling;
          wordsArray[j].parentNode.insertBefore(wordsArray[i], wordsArray[j]);
          parent.insertBefore(wordsArray[j], sibling);
        }
      }
    }

    customElements.define('word-cloud-{{ ai_gen_id }}', WordCloud{{ ai_gen_id }});
  })();
</script>

