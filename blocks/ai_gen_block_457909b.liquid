{% doc %}
  @prompt
    Create a text element that can be used as a prehead with a little animation to it. The element goes above a header sometimes., Make this prehead a pill / bubble. Remove the animation. Make the font dropdown select the typography, header, subhead, accent, Remove the bubble style from the prehead but add the ability to have different underlines
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-prehead-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
  }

  .ai-prehead-text-{{ ai_gen_id }} {
    display: inline-block;
    {% if block.settings.font_type == 'body' %}
      font-family: {{ settings.type_body_font.family }}, {{ settings.type_body_font.fallback_families }};
      font-weight: {{ settings.type_body_font.weight }};
    {% elsif block.settings.font_type == 'subheading' %}
      font-family: {{ settings.type_subheading_font.family }}, {{ settings.type_subheading_font.fallback_families }};
      font-weight: {{ settings.type_subheading_font.weight }};
    {% elsif block.settings.font_type == 'heading' %}
      font-family: {{ settings.type_heading_font.family }}, {{ settings.type_heading_font.fallback_families }};
      font-weight: {{ settings.type_heading_font.weight }};
    {% elsif block.settings.font_type == 'accent' %}
      font-family: {{ settings.type_accent_font.family }}, {{ settings.type_accent_font.fallback_families }};
      font-weight: {{ settings.type_accent_font.weight }};
    {% endif %}
    font-size: {{ block.settings.font_size }}px;
    color: {{ block.settings.text_color }};
    text-transform: {{ block.settings.text_transform }};
    letter-spacing: {{ block.settings.letter_spacing }}px;
    margin: 0;
    {% if block.settings.underline_style != 'none' %}
      text-decoration: underline;
      text-decoration-color: {{ block.settings.underline_color }};
      text-decoration-thickness: {{ block.settings.underline_thickness }}px;
      {% if block.settings.underline_style == 'solid' %}
        text-decoration-style: solid;
      {% elsif block.settings.underline_style == 'double' %}
        text-decoration-style: double;
      {% elsif block.settings.underline_style == 'dotted' %}
        text-decoration-style: dotted;
      {% elsif block.settings.underline_style == 'dashed' %}
        text-decoration-style: dashed;
      {% elsif block.settings.underline_style == 'wavy' %}
        text-decoration-style: wavy;
      {% endif %}
      text-underline-offset: {{ block.settings.underline_offset }}px;
    {% else %}
      text-decoration: none;
    {% endif %}
  }

  .ai-prehead-wrapper-{{ ai_gen_id }} {
    text-align: {{ block.settings.text_alignment }};
  }

  @media screen and (max-width: 749px) {
    .ai-prehead-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.font_size | times: 0.8 }}px;
    }
  }
{% endstyle %}

<div class="ai-prehead-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-prehead-wrapper-{{ ai_gen_id }}">
    {% if block.settings.prehead_text != blank %}
      <span class="ai-prehead-text-{{ ai_gen_id }}">{{ block.settings.prehead_text }}</span>
    {% else %}
      <span class="ai-prehead-text-{{ ai_gen_id }}" style="color: #999;">Add your prehead text</span>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Prehead",
  "settings": [
    {
      "type": "inline_richtext",
      "id": "prehead_text",
      "label": "Text",
      "default": "Introducing"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "select",
      "id": "font_type",
      "label": "Font",
      "options": [
        {
          "value": "body",
          "label": "Body"
        },
        {
          "value": "subheading",
          "label": "Subheading"
        },
        {
          "value": "heading",
          "label": "Heading"
        },
        {
          "value": "accent",
          "label": "Accent"
        }
      ],
      "default": "subheading"
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "Font size",
      "min": 10,
      "max": 32,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#000000"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "left"
    },
    {
      "type": "select",
      "id": "text_transform",
      "label": "Text case",
      "options": [
        {
          "value": "none",
          "label": "Default"
        },
        {
          "value": "uppercase",
          "label": "Uppercase"
        },
        {
          "value": "lowercase",
          "label": "Lowercase"
        },
        {
          "value": "capitalize",
          "label": "Capitalize"
        }
      ],
      "default": "uppercase"
    },
    {
      "type": "range",
      "id": "letter_spacing",
      "label": "Letter spacing",
      "min": 0,
      "max": 5,
      "step": 0.5,
      "unit": "px",
      "default": 1
    },
    {
      "type": "header",
      "content": "Underline"
    },
    {
      "type": "select",
      "id": "underline_style",
      "label": "Style",
      "options": [
        {
          "value": "none",
          "label": "None"
        },
        {
          "value": "solid",
          "label": "Solid"
        },
        {
          "value": "double",
          "label": "Double"
        },
        {
          "value": "dotted",
          "label": "Dotted"
        },
        {
          "value": "dashed",
          "label": "Dashed"
        },
        {
          "value": "wavy",
          "label": "Wavy"
        }
      ],
      "default": "none"
    },
    {
      "type": "color",
      "id": "underline_color",
      "label": "Color",
      "default": "#ff009d"
    },
    {
      "type": "range",
      "id": "underline_thickness",
      "label": "Thickness",
      "min": 1,
      "max": 6,
      "step": 1,
      "unit": "px",
      "default": 2
    },
    {
      "type": "range",
      "id": "underline_offset",
      "label": "Offset",
      "min": 0,
      "max": 10,
      "step": 1,
      "unit": "px",
      "default": 4
    }
  ],
  "presets": [
    {
      "name": "Prehead"
    }
  ]
}
{% endschema %}
