{% doc %}
  @prompt
    Create an icon list that the list items can be inline or stacked. Each item in the list can also be line or stacked (on a block level). Icon should have width / height settings. title can have background, border settings. Icon alignment can be left, right with vertical alignment, start, middle, end. No of Items can range from 0 to 20.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-icon-list-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
  }

  .ai-icon-list__container-{{ ai_gen_id }} {
    display: flex;
    {% if block.settings.list_layout == 'inline' %}
      flex-direction: row;
      flex-wrap: wrap;
      gap: {{ block.settings.list_gap }}px;
    {% else %}
      flex-direction: column;
      gap: {{ block.settings.list_gap }}px;
    {% endif %}
  }

  .ai-icon-list__item-{{ ai_gen_id }} {
    display: flex;
    {% if block.settings.item_layout == 'inline' %}
      flex-direction: row;
      align-items: {{ block.settings.icon_vertical_alignment }};
      gap: {{ block.settings.item_gap }}px;
    {% else %}
      flex-direction: column;
      align-items: {{ block.settings.icon_horizontal_alignment }};
      gap: {{ block.settings.item_gap }}px;
    {% endif %}
    {% if block.settings.list_layout == 'inline' %}
      flex: 1 1 auto;
    {% endif %}
  }

  .ai-icon-list__icon-wrapper-{{ ai_gen_id }} {
    flex-shrink: 0;
    {% if block.settings.item_layout == 'inline' %}
      order: {% if block.settings.icon_position == 'left' %}0{% else %}1{% endif %};
    {% endif %}
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
  }

  .ai-icon-list__icon-{{ ai_gen_id }} {
    height: 100%;
    color: {{ block.settings.icon_color }};
    width: 100%;
  }

  .ai-icon-list__icon-placeholder-{{ ai_gen_id }} {
    width: {{ block.settings.icon_width }}px;
    height: {{ block.settings.icon_height }}px;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-icon-list__icon-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-icon-list__content-{{ ai_gen_id }} {
    flex: 1;
    {% if block.settings.item_layout == 'inline' %}
      order: {% if block.settings.icon_position == 'left' %}1{% else %}0{% endif %};
    {% endif %}
  }

  .ai-icon-list__title-{{ ai_gen_id }} {
    margin: 0;
    padding: {{ block.settings.title_padding_vertical }}px {{ block.settings.title_padding_horizontal }}px;
    background-color: {{ block.settings.title_background_color }};
    border: {{ block.settings.title_border_width }}px solid {{ block.settings.title_border_color }};
    border-radius: {{ block.settings.title_border_radius }}px;
    color: {{ block.settings.title_text_color }};
    font-size: {{ block.settings.title_font_size }}px;
    {% if block.settings.item_layout == 'stacked' %}
      text-align: {{ block.settings.icon_horizontal_alignment }};
    {% endif %}
  }

  .ai-icon-list__description-{{ ai_gen_id }} {
    margin: 8px 0 0 0;
    color: {{ block.settings.description_text_color }};
    font-size: {{ block.settings.description_font_size }}px;
    {% if block.settings.item_layout == 'stacked' %}
      text-align: {{ block.settings.icon_horizontal_alignment }};
    {% endif %}
  }

  @media screen and (max-width: 749px) {
    .ai-icon-list-{{ ai_gen_id }} {
      display: block;
      width: {{ block.settings.mobile_width_percent }}%;
      max-width: 100%;
    }

    .ai-icon-list__container-{{ ai_gen_id }} {
      {% if block.settings.mobile_list_layout == 'stacked' %}
        flex-direction: column;
      {% endif %}
    }
  }
{% endstyle %}

<icon-list-{{ ai_gen_id }} class="ai-icon-list-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-icon-list__container-{{ ai_gen_id }}">
    {% for i in (1..20) %}
      {% liquid
        assign item_enabled_key = 'item_' | append: i | append: '_enabled'
        assign item_icon_key = 'item_' | append: i | append: '_icon'
        assign item_title_key = 'item_' | append: i | append: '_title'
        assign item_description_key = 'item_' | append: i | append: '_description'

        assign item_enabled = block.settings[item_enabled_key]
        assign item_icon = block.settings[item_icon_key]
        assign item_title = block.settings[item_title_key]
        assign item_description = block.settings[item_description_key]
      %}

      {% if item_enabled %}
        <div class="ai-icon-list__item-{{ ai_gen_id }}">
          <div class="ai-icon-list__icon-wrapper-{{ ai_gen_id }}">
            {% if item_icon %}
              <div class="ai-icon-list__icon-{{ ai_gen_id }}">
                <i class="{{ item_icon }}"></i>
              </div>
            {% else %}
              <div class="ai-icon-list__icon-placeholder-{{ ai_gen_id }}">
                {{ 'image' | placeholder_svg_tag }}
              </div>
            {% endif %}
          </div>

          <div class="ai-icon-list__content-{{ ai_gen_id }}">
            {% if item_title != blank %}
              <h3 class="ai-icon-list__title-{{ ai_gen_id }}">{{ item_title }}</h3>
            {% endif %}
            {% if item_description != blank %}
              <div class="ai-icon-list__description-{{ ai_gen_id }}">{{ item_description }}</div>
            {% endif %}
          </div>
        </div>
      {% endif %}
    {% endfor %}
  </div>
</icon-list-{{ ai_gen_id }}>

<script>
  (function() {
    class IconList{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
      }
    }

    customElements.define('icon-list-{{ ai_gen_id }}', IconList{{ ai_gen_id }});
  })();
</script>

