{% doc %}
  @prompt
    This is a callout grid. Columns can range from 0 to 5. A tile should have the ability to have an image, title, description and button. Not all the content needs to be filled out in the tile., tiles should have the ability to have alignment, left, center or right
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-callout-grid-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding }}px 0;
  }

  .ai-callout-grid__container-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    gap: {{ block.settings.grid_gap }}px;
    width: 100%;
  }

  .ai-callout-grid__tile-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: {{ block.settings.tile_alignment }};
    text-align: {{ block.settings.tile_text_alignment }};
    background-color: {{ block.settings.tile_background_color }};
    border-radius: {{ block.settings.tile_border_radius }}px;
    overflow: hidden;
    padding: {{ block.settings.tile_padding }}px;
    {% if block.settings.show_tile_border %}
      border: {{ block.settings.tile_border_width }}px solid {{ block.settings.tile_border_color }};
    {% endif %}
  }

  .ai-callout-grid__image-wrapper-{{ ai_gen_id }} {
    width: 100%;
    margin-bottom: {{ block.settings.tile_padding }}px;
  }

  .ai-callout-grid__image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ai-callout-grid__image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 16 / 9;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ai-callout-grid__image-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-callout-grid__content-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.content_gap }}px;
    flex-grow: 1;
    width: 100%;
  }

  .ai-callout-grid__title-{{ ai_gen_id }} {
    margin: 0;
    color: {{ block.settings.title_color }};
    font-size: {{ block.settings.title_size }}px;
    font-weight: 700;
  }

  .ai-callout-grid__description-{{ ai_gen_id }} {
    margin: 0;
    color: {{ block.settings.description_color }};
    font-size: {{ block.settings.description_size }}px;
    line-height: 1.6;
  }

  .ai-callout-grid__button-wrapper-{{ ai_gen_id }} {
    margin-top: auto;
    padding-top: {{ block.settings.content_gap }}px;
  }

  @media screen and (max-width: 749px) {
    .ai-callout-grid__container-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
    }
  }
{% endstyle %}

<callout-grid-{{ ai_gen_id }} class="ai-callout-grid-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-callout-grid__container-{{ ai_gen_id }}">
    {% for i in (1..5) %}
      {% liquid
        assign tile_enabled_key = 'tile_' | append: i | append: '_enabled'
        assign tile_image_key = 'tile_' | append: i | append: '_image'
        assign tile_title_key = 'tile_' | append: i | append: '_title'
        assign tile_description_key = 'tile_' | append: i | append: '_description'
        assign tile_button_text_key = 'tile_' | append: i | append: '_button_text'
        assign tile_button_link_key = 'tile_' | append: i | append: '_button_link'

        assign tile_enabled = block.settings[tile_enabled_key]
        assign tile_image = block.settings[tile_image_key]
        assign tile_title = block.settings[tile_title_key]
        assign tile_description = block.settings[tile_description_key]
        assign tile_button_text = block.settings[tile_button_text_key]
        assign tile_button_link = block.settings[tile_button_link_key]
      %}

      {% if tile_enabled %}
        <div class="ai-callout-grid__tile-{{ ai_gen_id }} ai-callout-grid__tile-{{ ai_gen_id }}">
          {% if tile_image != blank %}
            <div class="ai-callout-grid__image-wrapper-{{ ai_gen_id }}">
              <img
                src="{{ tile_image | image_url: width: 800 }}"
                alt="{{ tile_image.alt | escape }}"
                loading="lazy"
                width="{{ tile_image.width }}"
                height="{{ tile_image.height }}"
                class="ai-callout-grid__image-{{ ai_gen_id }}"
              >
            </div>
          {% endif %}

          <div class="ai-callout-grid__content-{{ ai_gen_id }}">
            {% if tile_title != blank %}
              <h3 class="ai-callout-grid__title-{{ ai_gen_id }}">{{ tile_title }}</h3>
            {% endif %}

            {% if tile_description != blank %}
              <div class="ai-callout-grid__description-{{ ai_gen_id }}">{{ tile_description }}</div>
            {% endif %}

            {% if tile_button_text != blank and tile_button_link != blank %}
              <div class="ai-callout-grid__button-wrapper-{{ ai_gen_id }}">
                <a href="{{ tile_button_link }}" class="button">
                  {{ tile_button_text }}
                </a>
              </div>
            {% endif %}
          </div>
        </div>
      {% endif %}
    {% endfor %}
  </div>
</callout-grid-{{ ai_gen_id }}>

<script>
  (function() {
    class CalloutGrid{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.style.display = 'block';
      }
    }

    customElements.define('callout-grid-{{ ai_gen_id }}', CalloutGrid{{ ai_gen_id }});
  })();
</script>

