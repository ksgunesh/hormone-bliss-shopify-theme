{% doc %}
  @prompt
    Create an icon list where the icon can be aligned top, middle and bottom with the text next to the icon. The icon can either be inline or stacked. Each entry can possibly have a link. Icon can have different color on the block level. So can the text. 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-icon-list-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
  }

  .ai-icon-list__container-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.item_spacing }}px;
  }

  .ai-icon-list__item-{{ ai_gen_id }} {
    display: flex;
    {% if block.settings.layout == 'inline' %}
      flex-direction: row;
      align-items: {{ block.settings.icon_alignment }};
      gap: {{ block.settings.icon_text_gap }}px;
    {% else %}
      flex-direction: column;
      align-items: flex-start;
      gap: {{ block.settings.icon_text_gap }}px;
    {% endif %}
  }

  .ai-icon-list__icon-wrapper-{{ ai_gen_id }} {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
  }

  .ai-icon-list__icon-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    color: {{ block.settings.icon_color }};
  }

  .ai-icon-list__content-{{ ai_gen_id }} {
    flex: 1;
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.text_size }}px;
    line-height: 1.5;
  }

  .ai-icon-list__link-{{ ai_gen_id }} {
    text-decoration: none;
    color: inherit;
    display: flex;
    {% if block.settings.layout == 'inline' %}
      flex-direction: row;
      align-items: {{ block.settings.icon_alignment }};
      gap: {{ block.settings.icon_text_gap }}px;
    {% else %}
      flex-direction: column;
      align-items: flex-start;
      gap: {{ block.settings.icon_text_gap }}px;
    {% endif %}
    transition: opacity 0.2s ease;
  }

  .ai-icon-list__link-{{ ai_gen_id }}:hover {
    opacity: 0.7;
  }

  @media screen and (max-width: 749px) {
    .ai-icon-list-{{ ai_gen_id }} {
      width: 100%;
    }
  }
{% endstyle %}

<icon-list-{{ ai_gen_id }} class="ai-icon-list-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-icon-list__container-{{ ai_gen_id }}">
    {% for i in (1..5) %}
      {% liquid
        assign item_enabled_key = 'item_' | append: i | append: '_enabled'
        assign item_icon_key = 'item_' | append: i | append: '_icon'
        assign item_text_key = 'item_' | append: i | append: '_text'
        assign item_link_key = 'item_' | append: i | append: '_link'

        assign item_enabled = block.settings[item_enabled_key]
        assign item_icon = block.settings[item_icon_key]
        assign item_text = block.settings[item_text_key]
        assign item_link = block.settings[item_link_key]
      %}

      {% if item_enabled %}
        <div class="ai-icon-list__item-{{ ai_gen_id }}">
          {% if item_link != blank %}
            <a href="{{ item_link }}" class="ai-icon-list__link-{{ ai_gen_id }}">
              <div class="ai-icon-list__icon-wrapper-{{ ai_gen_id }}">
                {% case item_icon %}
                  {% when 'checkmark' %}
                    <svg class="ai-icon-list__icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <polyline points="20 6 9 17 4 12"></polyline>
                    </svg>
                  {% when 'star' %}
                    <svg class="ai-icon-list__icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon>
                    </svg>
                  {% when 'heart' %}
                    <svg class="ai-icon-list__icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
                    </svg>
                  {% when 'shield' %}
                    <svg class="ai-icon-list__icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
                    </svg>
                  {% when 'truck' %}
                    <svg class="ai-icon-list__icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <rect x="1" y="3" width="15" height="13"></rect>
                      <polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon>
                      <circle cx="5.5" cy="18.5" r="2.5"></circle>
                      <circle cx="18.5" cy="18.5" r="2.5"></circle>
                    </svg>
                  {% when 'gift' %}
                    <svg class="ai-icon-list__icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <polyline points="20 12 20 22 4 22 4 12"></polyline>
                      <rect x="2" y="7" width="20" height="5"></rect>
                      <line x1="12" y1="22" x2="12" y2="7"></line>
                      <path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z"></path>
                      <path d="M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z"></path>
                    </svg>
                  {% when 'clock' %}
                    <svg class="ai-icon-list__icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <circle cx="12" cy="12" r="10"></circle>
                      <polyline points="12 6 12 12 16 14"></polyline>
                    </svg>
                  {% when 'leaf' %}
                    <svg class="ai-icon-list__icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10Z"></path>
                      <path d="M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12"></path>
                    </svg>
                  {% when 'award' %}
                    <svg class="ai-icon-list__icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <circle cx="12" cy="8" r="7"></circle>
                      <polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"></polyline>
                    </svg>
                  {% when 'zap' %}
                    <svg class="ai-icon-list__icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon>
                    </svg>
                {% endcase %}
              </div>
              <div class="ai-icon-list__content-{{ ai_gen_id }}">
                {{ item_text }}
              </div>
            </a>
          {% else %}
            <div class="ai-icon-list__icon-wrapper-{{ ai_gen_id }}">
              {% case item_icon %}
                {% when 'checkmark' %}
                  <svg class="ai-icon-list__icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
